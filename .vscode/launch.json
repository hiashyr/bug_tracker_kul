{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "flutterMode": "debug",
        "args": [
          "--web-port=62044",
          "--web-browser-flag=--disable-web-security"
        ],
    }
  ]
}